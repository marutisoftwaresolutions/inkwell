@model Blog.Core.Domain.Post

<article class="group flex flex-col overflow-hidden rounded-2xl border transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5"
         style="background: var(--card); border-color: var(--border);">

    <a href="/@Model.Slug" class="relative overflow-hidden aspect-[120/63] block" style="background: var(--muted);">
        @if (!string.IsNullOrEmpty(Model.FeatureImage))
        {
            <img src="@Model.FeatureImage" alt="@Model.Title"
                 class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                 asp-append-version="true"
                 loading="lazy" />
        }
        else
        {
            <div class="absolute inset-0 flex items-center justify-center"
                 style="background: linear-gradient(135deg, var(--accent), var(--muted));">
                <span class="text-6xl font-black opacity-10" style="color: var(--foreground);">@Model.Title.FirstOrDefault()</span>
            </div>
        }
        @if (Model.Categories != null && Model.Categories.Any())
        {
            <span class="absolute top-3 left-3 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider"
                  style="background: var(--primary); color: var(--primary-foreground);">
                @Model.Categories.First().Name
            </span>
        }
    </a>

    <div class="flex flex-col flex-1 p-5 gap-3">
        <time class="text-[11px] font-semibold uppercase tracking-widest" style="color: var(--muted-foreground);">
            @Model.PublishedAt?.ToString("MMM d, yyyy")
        </time>

        <h3 class="text-lg font-bold leading-snug line-clamp-2">
            <a href="/@Model.Slug" class="hover:opacity-70 transition-opacity" style="color: var(--card-foreground);">
                @Model.Title
            </a>
        </h3>

        <p class="text-sm line-clamp-3 leading-relaxed flex-1" style="color: var(--muted-foreground);">
            @(!string.IsNullOrEmpty(Model.MetaDescription) ? Model.MetaDescription : Model.Plaintext)
        </p>

        <div class="mt-auto pt-4 flex items-center justify-between border-t" style="border-color: var(--border);">
            <div class="flex items-center gap-2">
                <img src="/avatar/@System.Net.WebUtility.UrlEncode(string.IsNullOrEmpty(Model.AuthorName) ? "A" : Model.AuthorName)"
                     alt="@Model.AuthorName" class="w-7 h-7 rounded-full" />
                <span class="text-xs font-medium" style="color: var(--foreground);">
                    @(string.IsNullOrEmpty(Model.AuthorName) ? "Anonymous" : Model.AuthorName)
                </span>
            </div>
            <a href="/@Model.Slug" class="text-xs font-bold uppercase tracking-wider hover:opacity-60 transition-opacity"
               style="color: var(--primary);">Read →</a>
        </div>
    </div>
</article>
