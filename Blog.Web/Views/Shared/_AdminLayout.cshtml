@using System.Security.Claims
@inject Blog.Core.Interfaces.IUserRepository UsersRepo
@inject Blog.Core.Interfaces.ISettingRepository SettingsRepo
@inject Blog.Core.Interfaces.ITenantContext TenantContext
@{
    // Resolve Site Name for Sidebar
    var primaryAdmin = await UsersRepo.GetFirstAdminAsync();
    var ownerId = primaryAdmin?.Id ?? Guid.Empty;
    var settings = await SettingsRepo.GetSettingsAsync(ownerId);
    var siteName = settings?.SiteName ?? "BLGFRNT";
    var siteInitial = !string.IsNullOrEmpty(siteName) ? siteName[0] : 'B';
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Admin</title>
    
    @if (!string.IsNullOrWhiteSpace(settings?.GoogleAnalyticsId))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@settings.GoogleAnalyticsId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@settings.GoogleAnalyticsId');
        </script>
    }
    <!-- Inkwell Fonts (self-hosted) -->
    <link rel="stylesheet" href="~/fonts/fonts.css" asp-append-version="true" />
    <!-- Inkwell design tokens -->
    <link rel="stylesheet" href="~/css/inkwell.css" asp-append-version="true" />
    <!-- Admin stylesheet -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <!-- Lucide icons (self-hosted) -->
    <script src="~/lib/lucide/lucide.min.js"></script>

    <!-- Tailwind CSS (self-hosted) -->
    <script src="~/lib/tailwindcss/tailwind.js"></script>
    <script defer src="~/lib/alpinejs/alpine.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        background: 'var(--background)',
                        foreground: 'var(--foreground)',
                        card: 'var(--card)',
                        'card-foreground': 'var(--card-foreground)',
                        popover: 'var(--popover)',
                        'popover-foreground': 'var(--popover-foreground)',
                        primary: 'var(--primary)',
                        'primary-foreground': 'var(--primary-foreground)',
                        secondary: 'var(--secondary)',
                        'secondary-foreground': 'var(--secondary-foreground)',
                        muted: 'var(--muted)',
                        'muted-foreground': 'var(--muted-foreground)',
                        accent: 'var(--accent)',
                        'accent-foreground': 'var(--accent-foreground)',
                        destructive: 'var(--destructive)',
                        'destructive-foreground': 'var(--destructive-foreground)',
                        border: 'var(--border)',
                        input: 'var(--input)',
                        ring: 'var(--ring)',
                        sidebar: 'var(--sidebar)',
                        'sidebar-foreground': 'var(--sidebar-foreground)',
                        'sidebar-primary': 'var(--sidebar-primary)',
                        'sidebar-primary-foreground': 'var(--sidebar-primary-foreground)',
                        'sidebar-accent': 'var(--sidebar-accent)',
                        'sidebar-accent-foreground': 'var(--sidebar-accent-foreground)',
                        'sidebar-border': 'var(--sidebar-border)',
                    },
                    fontFamily: {
                        sans: ["'Geist'", 'Inter', 'system-ui', 'sans-serif'],
                        serif: ["'Source Serif 4'", 'Georgia', 'serif'],
                    },
                    borderRadius: {
                        DEFAULT: 'var(--radius)',
                    }
                }
            }
        }
    </script>

    <style>
        /* ── Inkwell Editorial Desk palette ─────────────────────────── */
        :root {
            --background:                 #FAF7F2;  /* ink-cream */
            --foreground:                 #1A1A1A;  /* ink-black */
            --card:                       #F4EFE6;  /* surface */
            --card-foreground:            #1A1A1A;
            --popover:                    #FAF7F2;
            --popover-foreground:         #1A1A1A;
            --primary:                    #1A1A1A;  /* ink-black — Compose button bg */
            --primary-foreground:         #FAF7F2;  /* cream — Compose button text */
            --secondary:                  #F4EFE6;  /* surface */
            --secondary-foreground:       #1A1A1A;
            --muted:                      #EFE9DC;  /* surface-2 */
            --muted-foreground:           #8B7355;  /* ink-sepia */
            --accent:                     #E8E1D3;  /* cream-edge — hover bg */
            --accent-foreground:          #1A1A1A;
            --destructive:                #8C2A1F;  /* burgundy */
            --destructive-foreground:     #FAF7F2;
            --border:                     #E8E1D3;
            --input:                      #E8E1D3;
            --ring:                       #1A1A1A;
            --sidebar:                    #F4EFE6;  /* slightly off-cream sidebar */
            --sidebar-foreground:         #1A1A1A;
            --sidebar-primary:            #1A1A1A;  /* active nav bg */
            --sidebar-primary-foreground: #FAF7F2;
            --sidebar-accent:             #EFE9DC;  /* hover bg */
            --sidebar-accent-foreground:  #1A1A1A;
            --sidebar-border:             #E8E1D3;
            --sidebar-ring:               #1A1A1A;
            --radius:                     2px;
        }

        body {
            background-color: var(--background);
            color: var(--foreground);
            font-family: 'Geist', 'Inter', system-ui, sans-serif;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 0; }
        ::-webkit-scrollbar-thumb:hover { background: var(--muted-foreground); }
    </style>
</head>
<body class="min-h-screen flex antialiased">
    
    <!-- Sidebar -->
    <aside id="sidebar" class="w-64 bg-sidebar border-r border-sidebar-border hidden md:flex flex-col fixed inset-y-0 left-0 z-50 transition-transform duration-300 transform -translate-x-full md:translate-x-0">
        <div class="h-16 flex items-center px-6">
            <div class="flex items-center gap-2 font-bold text-xl text-sidebar-foreground">
                <div class="w-8 h-8 rounded bg-sidebar-primary text-sidebar-primary-foreground flex items-center font-normal justify-center">
                    @siteInitial
                </div>
                <span>@siteName</span>
            </div>
            <button class="md:hidden ml-auto group" onclick="document.getElementById('sidebar').classList.add('-translate-x-full')">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>

        <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-1">
            @{
                var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                var action = ViewContext.RouteData.Values["action"]?.ToString();
                string NavClass(string ctrl, string? act = null) {
                    bool isActive = (ctrl == controller && (act == null || act == action));
                    return isActive 
                        ? "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md bg-sidebar-accent text-sidebar-accent-foreground"
                        : "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-sidebar-foreground hover:bg-sidebar-accent/50 hover:text-sidebar-accent-foreground transition-colors";
                }
            }

            <a href="/admin/dashboard" class="@NavClass("Dashboard")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                Dashboard
            </a>
            
            <a href="/admin/posts" class="@NavClass("Posts")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                Posts
            </a>

            <a href="/admin/categories" class="@NavClass("Categories")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                Categories
            </a>

            <a href="/admin/tags" class="@NavClass("Tags")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                Tags
            </a>

            <a href="/admin/pages" class="@NavClass("Pages")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                Pages
            </a>
            
            <a href="/admin/media" class="@NavClass("Media")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                Media
            </a>
            
            <a href="/admin/comments" class="@NavClass("Comments")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Comments
            </a>

            <a href="/admin/analytics" class="@NavClass("Analytics")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Analytics
            </a>

            <div class="pt-4 mt-4 border-t border-sidebar-border">
                 <p class="px-3 text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Settings</p>
            </div>

            <a href="/admin/settings" class="@NavClass("Settings")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                General
            </a>

            @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
            {
                <a href="/admin/users" class="@NavClass("Users")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Users
                </a>
            }

            <a href="/admin/theme" class="@NavClass("ThemeSettings")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.63 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-1 0-.83.67-1.5 1.5-1.5H16c3.31 0 6-2.69 6-6 0-5.17-4.49-9-10-9z"/></svg>
                Theme
            </a>

            <a href="/account/profile" class="@NavClass("Account", "Profile")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Profile
            </a>
             <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-md text-sidebar-foreground hover:bg-sidebar-accent/50 hover:text-sidebar-accent-foreground transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                View Site
            </a>
        </nav>

        <div class="p-4 border-t border-sidebar-border">
             <form method="post" asp-controller="Account" asp-action="Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-2 justify-center px-4 py-2 text-sm font-medium text-destructive bg-transparent border border-destructive rounded-md hover:bg-destructive hover:text-white transition-colors shadow-sm">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    Logout
                </button>
            </form>
        </div>
    </aside>

    <!-- Overlay for mobile -->
    <div id="sidebar-overlay" onclick="document.getElementById('sidebar').classList.remove('translate-x-0'); document.getElementById('sidebar').classList.add('-translate-x-full'); this.classList.add('hidden')" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"></div>

    <!-- Main Content -->
    <main class="flex-1 md:ml-64 flex flex-col min-h-screen">
        <!-- Topbar -->
        <header class="h-16 flex items-center justify-between px-6 border-b border-border bg-background sticky top-0 z-30">
            <div class="flex items-center gap-4">
                <button class="md:hidden text-foreground p-1 hover:bg-muted rounded" onclick="document.getElementById('sidebar').classList.remove('-translate-x-full'); document.getElementById('sidebar').classList.add('translate-x-0'); document.getElementById('sidebar-overlay').classList.remove('hidden')">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
                </button>
                <h1 class="text-xl font-bold tracking-tight text-foreground">@ViewData["Title"]</h1>
            </div>
            <div class="flex items-center gap-4">
                 <div class="flex items-center gap-2 pl-1.5 pr-3 py-1.5 bg-secondary text-secondary-foreground rounded-full text-sm font-medium shadow-sm border border-secondary-foreground/20">
                    @{
                        var userIdString = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        string? adminAvatarUrl = null;
                        if (Guid.TryParse(userIdString, out var uid)) {
                            var u = await UsersRepo.GetByIdAsync(uid);
                            adminAvatarUrl = u?.AvatarUrl;
                        }
                        var avatarSrc = !string.IsNullOrEmpty(adminAvatarUrl) 
                            ? adminAvatarUrl 
                            : $"/avatar/{System.Net.WebUtility.UrlEncode(User.Identity?.Name ?? "A")}";
                    }
                    <div class="w-7 h-7 rounded-full overflow-hidden bg-background border border-secondary-foreground/20 shadow-sm flex-shrink-0">
                        <img src="@avatarSrc" alt="Avatar" class="w-full h-full object-cover" loading="lazy" />
                    </div>
                    @User.Identity?.Name
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="p-6">
            <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2 max-w-sm w-full" style="pointer-events: none;">
                @if (TempData["Success"] != null)
                {
                    <div id="toast-success" class="p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 flex items-center gap-2 shadow-lg animate-slide-in-right pointer-events-auto">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-600 shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>@TempData["Success"]</span>
                        <button onclick="this.closest('div').remove()" class="ml-auto pl-2 text-green-600 hover:text-green-800"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div id="toast-error" class="p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 flex items-center gap-2 shadow-lg animate-slide-in-right pointer-events-auto">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-600 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                        <span>@TempData["Error"]</span>
                        <button onclick="this.closest('div').remove()" class="ml-auto pl-2 text-red-600 hover:text-red-800"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                    </div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div id="toast-warning" class="p-4 rounded-lg bg-yellow-50 border border-yellow-200 text-yellow-800 flex items-center gap-2 shadow-lg animate-slide-in-right pointer-events-auto">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-yellow-600 shrink-0"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        <span>@TempData["Warning"]</span>
                        <button onclick="this.closest('div').remove()" class="ml-auto pl-2 text-yellow-600 hover:text-yellow-800"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                    </div>
                }
                
                @if (!ViewData.ModelState.IsValid)
                {
                    foreach (var modelStateKey in ViewData.ModelState.Keys)
                    {
                        var modelStateVal = ViewData.ModelState[modelStateKey];
                        foreach (var error in modelStateVal.Errors)
                        {
                            <div class="toast-model-error p-4 rounded-lg bg-red-50 border border-red-200 text-red-800 flex items-center gap-2 shadow-lg animate-slide-in-right pointer-events-auto">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-red-600 shrink-0"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                <span>@error.ErrorMessage</span>
                                <button onclick="this.closest('div').remove()" class="ml-auto pl-2 text-red-600 hover:text-red-800"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
                            </div>
                        }
                    }
                }
            </div>

            <script>
                setTimeout(() => {
                    document.getElementById('toast-success')?.remove();
                    document.getElementById('toast-error')?.remove();
                    document.getElementById('toast-warning')?.remove();
                    document.querySelectorAll('.toast-model-error').forEach(e => e.remove());
                }, 8000);
            </script>

            @RenderBody()
        </div>
    </main>

    <script src="~/lib/htmx/htmx.min.js"></script>
    <!-- Highlight.js for Syntax Highlighting in Editor (self-hosted) -->
    <link rel="stylesheet" href="~/lib/highlightjs/github-dark.min.css">
    <script src="~/lib/highlightjs/highlight.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
