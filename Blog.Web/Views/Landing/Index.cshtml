  </header>

  <!-- ═══════════════════════ Hero ═══════════════════════ -->
  <section class="hero" id="hero">
    <div class="ink-cursor" id="inkCursor"></div>
    <div class="container hero-grid">
      <div>
        <div class="hero-eyebrow">
          <span><span class="dot"></span>v1.0 · Released</span>
          <span class="sep"></span>
          <span>MIT · .NET 10 · Multi-tenant</span>
