      <a class="brand" href="/">
        <img class="mark" src="~/assets/logomark.svg" alt="">
        <span class="word">Inkwell</span>
      </a>
      <nav class="header-nav">
        <a class="nav-link" href="#layouts">Layouts</a>
        <a class="nav-link" href="#presets">Presets</a>
