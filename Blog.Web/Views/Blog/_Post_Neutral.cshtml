@model Blog.Core.Domain.Post
@{
    var blogLayout = (string)(ViewBag.BlogLayout ?? "Neutral");
}

<!-- Neutral layout: dashed borders, sidebar, classic structure -->
<div class="container xl:max-w-6xl mx-auto px-4 py-6 lg:py-10">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm mb-6" style="color: var(--muted-foreground);">
        <a href="/" class="hover:opacity-80">Home</a>
        <i class="bi bi-chevron-right text-xs"></i>
        @if (Model.Categories.Any())
        {
            <a href="/?category=@Model.Categories.First().Slug" class="hover:opacity-80">@Model.Categories.First().Name</a>
            <i class="bi bi-chevron-right text-xs"></i>
        }
        <span>@Model.Title</span>
    </div>

    <!-- Main Article -->
    <article class="max-w-4xl mx-auto w-full">
            <!-- Header -->
            <header class="mb-8">
                <div class="flex flex-wrap gap-2 mb-4">
                    @foreach (var cat in Model.Categories)
                    {
                        <a href="/?category=@cat.Slug" class="text-xs uppercase font-bold px-3 py-1 border border-dashed hover:opacity-80" style="border-color: var(--border); background: var(--muted);">@cat.Name</a>
                    }
                </div>

                <h1 class="text-3xl md:text-4xl font-medium mb-4 leading-tight">@Model.Title</h1>

                <div class="flex items-center gap-4 text-sm border-b border-dashed pb-4" style="color: var(--muted-foreground); border-color: var(--border);">
                    <div class="flex items-center gap-2">
                        @{
                            var pAuthorImage = !string.IsNullOrEmpty(Model.AvatarUrl)
                                ? Model.AvatarUrl
                                : $"/avatar/{System.Net.WebUtility.UrlEncode(string.IsNullOrEmpty(Model.AuthorName) ? "A" : Model.AuthorName)}";
                            var readingMinutes = Math.Max(1, (Model.Plaintext?.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length ?? 0) / 238);
                        }
                        <img src="@pAuthorImage" alt="@Model.AuthorName" class="w-8 h-8 rounded-full object-cover" />
                        <span>
                            <span class="font-medium" style="color: var(--foreground);">@(string.IsNullOrEmpty(Model.AuthorName) ? "Anonymous" : Model.AuthorName)@(!string.IsNullOrEmpty(Model.AuthorCredentials) ? $", {Model.AuthorCredentials}" : "")</span>
                            @if (!string.IsNullOrEmpty(Model.AuthorSpecialty))
                            {
                                <span class="block text-xs" style="color: var(--muted-foreground);">@Model.AuthorSpecialty</span>
                            }
                        </span>
                    </div>
                    <span>•</span>
                    <time datetime="@Model.PublishedAt?.ToString("yyyy-MM-dd")">
                        <i class="bi bi-calendar me-1"></i>@Model.PublishedAt?.ToString("MMMM d, yyyy")
                    </time>
                    <span>•</span>
                    <span><i class="bi bi-clock me-1"></i>@readingMinutes min read</span>
                    <span>•</span>
                    <span><i class="bi bi-eye me-1"></i>@Model.ViewCount views</span>
                </div>

                @if (Model.LastVerifiedAt.HasValue || Model.NextReviewAt.HasValue)
                {
                    <div class="flex flex-wrap gap-x-5 gap-y-1 mt-3 text-xs" style="color: var(--muted-foreground);">
                        @if (Model.LastVerifiedAt.HasValue)
                        {
                            <span class="flex items-center gap-1">
                                <i class="bi bi-patch-check"></i>
                                Last verified: <strong style="color: var(--foreground);">@Model.LastVerifiedAt.Value.ToString("MMMM d, yyyy")</strong>
                            </span>
                        }
                        @if (Model.NextReviewAt.HasValue)
                        {
                            <span class="flex items-center gap-1">
                                <i class="bi bi-arrow-clockwise"></i>
                                Next review: <strong style="color: var(--foreground);">@Model.NextReviewAt.Value.ToString("MMMM d, yyyy")</strong>
                            </span>
                        }
                    </div>
                }
            </header>

            <!-- Featured Image -->
            @if (!string.IsNullOrEmpty(Model.FeatureImage))
            {
                <div class="mb-8 overflow-hidden">
                    <img src="@Model.FeatureImage" alt="@Model.Title" class="w-full h-auto object-cover" />
                </div>
            }

            <!-- Post Content -->
            <div class="post-prose mb-8" style="font-family: var(--font-body); line-height: 1.8;">
                @Html.Raw(Model.Html)
            </div>

            <!-- See Also (internal links) -->
            <partial name="_SeeAlso" view-data="ViewData" />

            <!-- FAQ Accordion -->
            @if (Model.Faqs.Any())
            {
                <div class="pt-6 border-t border-dashed" style="border-color: var(--border);">
                    <h2 class="text-xl font-medium mb-4">Frequently Asked Questions</h2>
                    <div class="space-y-2" itemscope itemtype="https://schema.org/FAQPage">
                        @foreach (var faq in Model.Faqs)
                        {
                            <div x-data="{ open: false }" class="border border-dashed rounded-lg overflow-hidden" style="border-color: var(--border);" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                                <button type="button" @@click="open = !open" class="w-full flex items-center justify-between px-4 py-3 text-left font-medium text-sm hover:opacity-80 transition-opacity" style="background: var(--muted);">
                                    <span itemprop="name">@faq.Question</span>
                                    <svg :class="open ? 'rotate-180' : ''" class="shrink-0 transition-transform ml-2" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                </button>
                                <div x-show="open" x-transition class="px-4 py-3 text-sm leading-relaxed" style="color: var(--foreground);" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                                    <span itemprop="text">@faq.Answer</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Tags -->
            @if (Model.Tags.Any())
            {
                <div class="pt-6 border-t border-dashed" style="border-color: var(--border);">
                    <h4 class="text-sm font-medium mb-3" style="color: var(--muted-foreground);">
                        <i class="bi bi-tags me-1"></i>Tags
                    </h4>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var tag in Model.Tags)
                        {
                            <a href="/?tags=@tag.Slug" class="py-1 px-3 text-sm border hover:opacity-80" style="background: var(--background); border-color: var(--border);">@tag.Name</a>
                        }
                    </div>
                </div>
            }

            <!-- Share -->
            <div class="flex items-center gap-3 mt-6 pt-6 border-t border-dashed" style="border-color: var(--border);">
                <span class="text-sm font-medium" style="color: var(--muted-foreground);">Share:</span>
                <a href="https://twitter.com/intent/tweet?url=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + "/" + Model.Slug)&text=@Uri.EscapeDataString(Model.Title)" target="_blank" class="p-2 hover:opacity-70"><i class="bi bi-twitter-x"></i></a>
                <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + "/" + Model.Slug)" target="_blank" class="p-2 hover:opacity-70"><i class="bi bi-facebook"></i></a>
                <a href="https://www.linkedin.com/shareArticle?mini=true&url=@Uri.EscapeDataString(Context.Request.Scheme + "://" + Context.Request.Host + "/" + Model.Slug)&title=@Uri.EscapeDataString(Model.Title)" target="_blank" class="p-2 hover:opacity-70"><i class="bi bi-linkedin"></i></a>
            </div>

            <!-- Related Posts -->
            @{
                var relatedPosts = ViewBag.RelatedPostCards as List<Blog.Core.Domain.Post>;
            }
            @if (relatedPosts != null && relatedPosts.Any())
            {
                <div class="mt-8 pt-8 border-t border-dashed" style="border-color: var(--border);">
                    <h3 class="text-lg font-medium mb-5">You May Also Like</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                        @foreach (var rp in relatedPosts)
                        {
                            var rpMinutes = Math.Max(1, (rp.Plaintext?.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length ?? 0) / 238);
                            <a href="/@rp.Slug" class="group border border-dashed rounded-lg overflow-hidden hover:shadow-md transition-shadow flex flex-col" style="border-color: var(--border); background: var(--card);">
                                @if (!string.IsNullOrEmpty(rp.FeatureImage))
                                {
                                    <img src="@rp.FeatureImage" alt="@rp.Title" class="w-full h-36 object-cover group-hover:opacity-90 transition-opacity" />
                                }
                                <div class="p-3 flex flex-col gap-1 flex-1">
                                    @if (rp.Categories.Any())
                                    {
                                        <span class="text-xs uppercase font-bold" style="color: var(--primary);">@rp.Categories.First().Name</span>
                                    }
                                    <p class="text-sm font-medium leading-snug line-clamp-2" style="color: var(--foreground);">@rp.Title</p>
                                    <p class="text-xs mt-auto pt-1" style="color: var(--muted-foreground);">@(string.IsNullOrEmpty(rp.AuthorName) ? "Anonymous" : rp.AuthorName) · @rpMinutes min read</p>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }
        </article>
</div>
