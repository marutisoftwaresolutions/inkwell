@model Blog.Core.Domain.Post
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = !string.IsNullOrEmpty(Model.MetaTitle) ? Model.MetaTitle : Model.Title;
    ViewData["Description"] = !string.IsNullOrEmpty(Model.MetaDescription) ? Model.MetaDescription : (Model.Plaintext?.Length > 160 ? Model.Plaintext.Substring(0, 157) + "..." : Model.Plaintext);
    ViewData["SiteName"] = ViewBag.SiteName ?? "Blog";
    ViewData["SiteLogoUrl"] = ViewBag.SiteLogoUrl ?? "";

    var blogLayout = (string)(ViewBag.LayoutPost ?? "Neutral");
}

@section MetaTags {
    <link rel="canonical" href="@(!string.IsNullOrEmpty(Model.CanonicalUrl) ? Model.CanonicalUrl : $"{Context.Request.Scheme}://{Context.Request.Host}/{Model.Slug}")" />
    <!-- Open Graph -->
    @{
        var ogImageUrl = !string.IsNullOrEmpty(Model.OgImage) ? Model.OgImage
            : !string.IsNullOrEmpty(Model.FeatureImage) ? Model.FeatureImage
            : $"{Context.Request.Scheme}://{Context.Request.Host}/og-image/{Model.Slug}.png";
        var twitterImageUrl = !string.IsNullOrEmpty(Model.TwitterImage) ? Model.TwitterImage
            : !string.IsNullOrEmpty(Model.FeatureImage) ? Model.FeatureImage
            : ogImageUrl;
    }
    <meta property="og:type" content="article" />
    <meta property="og:title" content="@(!string.IsNullOrEmpty(Model.OgTitle) ? Model.OgTitle : ViewData["Title"])" />
    <meta property="og:description" content="@(!string.IsNullOrEmpty(Model.OgDescription) ? Model.OgDescription : ViewData["Description"])" />
    <meta property="og:image" content="@ogImageUrl" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="@ViewData["SiteName"]" />
    @if (Model.PublishedAt.HasValue)
    {
        <meta property="article:published_time" content="@Model.PublishedAt.Value.ToString("O")" />
    }
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(!string.IsNullOrEmpty(Model.TwitterTitle) ? Model.TwitterTitle : ViewData["Title"])" />
    <meta name="twitter:description" content="@(!string.IsNullOrEmpty(Model.TwitterDescription) ? Model.TwitterDescription : ViewData["Description"])" />
    <meta name="twitter:image" content="@twitterImageUrl" />
    <partial name="_SchemaJsonLd" model="Model" view-data="ViewData" />
}

@if (blogLayout == "Magazine")
{
    <partial name="_Post_Magazine" model="Model" />
}
else
{
    <partial name="_Post_Neutral" model="Model" />
}

<!-- Newsletter Signup -->
<div class="max-w-4xl mx-auto px-4">
    <partial name="_NewsletterSignup" view-data="ViewData" />
</div>

<!-- Comments Section (Shared across layouts) -->
@if ((bool)(ViewBag.CommentsEnabled ?? false))
{
    var comments = (List<Blog.Core.Domain.Comment>)ViewBag.Comments;
    ViewData["PostSlug"] = Model.Slug;

    @if (blogLayout == "Magazine")
    {
        <section class="ink-comments">
            <h2 class="ink-comments-title">
                Letters <span class="meta" style="font-weight:400;">(@comments.Count)</span>
            </h2>
            @if (TempData["CommentSuccess"] != null)
            {
                <div style="padding:var(--sp-4);border:1px solid var(--border);background:var(--surface);font-family:var(--sans);font-size:14px;color:var(--fg-body);margin-bottom:var(--sp-6);">@TempData["CommentSuccess"]</div>
            }
            @if (TempData["CommentError"] != null)
            {
                <div style="padding:var(--sp-4);border:1px solid var(--ink-accent);background:var(--surface);font-family:var(--sans);font-size:14px;color:var(--ink-accent);margin-bottom:var(--sp-6);">@TempData["CommentError"]</div>
            }
            <div style="display:flex;flex-direction:column;gap:var(--sp-6);margin-bottom:var(--sp-10);">
                @foreach (var comment in comments)
                {
                    <partial name="_CommentThread" model="comment" view-data="ViewData" />
                }
            </div>
            <div class="ink-comment-form">
                <h3>Leave a letter</h3>
                <form method="post" action="/@Model.Slug/comment" style="display:flex;flex-direction:column;gap:var(--sp-6);">
                    @Html.AntiForgeryToken()
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-6);">
                        <div>
                            <label class="eyebrow" style="display:block;margin-bottom:var(--sp-2);">Name *</label>
                            <input type="text" name="authorName" class="ink-input" required placeholder="Your name" />
                        </div>
                        <div>
                            <label class="eyebrow" style="display:block;margin-bottom:var(--sp-2);">Email *</label>
                            <input type="email" name="authorEmail" class="ink-input" required placeholder="you@example.com" />
                        </div>
                    </div>
                    <div>
                        <label class="eyebrow" style="display:block;margin-bottom:var(--sp-2);">Letter *</label>
                        <textarea name="content" rows="5" class="ink-input" required
                                  style="resize:vertical;border:1px solid var(--ink-black);padding:var(--sp-3);border-radius:var(--r-1);font-family:var(--serif);font-size:var(--fs-body);line-height:var(--lh-prose);"
                                  placeholder="Write your thoughts…"></textarea>
                    </div>
                    <div>
                        <button type="submit" class="ink-btn">Post letter</button>
                    </div>
                </form>
            </div>
        </section>
    }
    else
    {
        <section class="max-w-4xl mx-auto px-4 py-8 lg:py-12">
            <div>
                <h2 class="text-xl font-medium mb-6 border-b border-dashed pb-2" style="border-color: var(--border);">
                    Comments <span class="text-sm font-normal" style="color: var(--muted-foreground);">(@comments.Count)</span>
                </h2>
                @if (TempData["CommentSuccess"] != null)
                {
                    <div class="mb-6 p-4 text-sm border border-dashed rounded-lg" style="background: var(--muted); border-color: var(--border);">@TempData["CommentSuccess"]</div>
                }
                @if (TempData["CommentError"] != null)
                {
                    <div class="mb-6 p-4 text-sm border border-dashed rounded-lg" style="background: var(--muted); border-color: var(--border); color: var(--destructive);">@TempData["CommentError"]</div>
                }
                <div class="space-y-6 mb-10">
                    @foreach (var comment in comments)
                    {
                        <partial name="_CommentThread" model="comment" view-data="ViewData" />
                    }
                </div>
                <div class="p-6 border border-dashed rounded-xl" style="background: var(--muted); border-color: var(--border);">
                    <h3 class="text-lg font-medium mb-4">Leave a Reply</h3>
                    <form method="post" action="/@Model.Slug/comment" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <div class="grid md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium mb-1" style="color: var(--foreground);">Name *</label>
                                <input type="text" name="authorName" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-1 focus:ring-primary" style="background: var(--background); border-color: var(--border); color: var(--foreground);" required />
                            </div>
                            <div>
                                <label class="block text-sm font-medium mb-1" style="color: var(--foreground);">Email *</label>
                                <input type="email" name="authorEmail" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-1 focus:ring-primary" style="background: var(--background); border-color: var(--border); color: var(--foreground);" required />
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-1" style="color: var(--foreground);">Comment *</label>
                            <textarea name="content" rows="4" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-1 focus:ring-primary resize-y" style="background: var(--background); border-color: var(--border); color: var(--foreground);" required></textarea>
                        </div>
                        <button type="submit" class="px-6 py-2.5 font-medium text-sm rounded-md hover:opacity-90 transition-opacity" style="background: var(--primary); color: var(--primary-foreground);">Post Comment</button>
                    </form>
                </div>
            </div>
        </section>
    }

    <script>
        function toggleReplyForm(btn) {
            var form = btn.nextElementSibling;
            if (!form || !form.classList.contains('reply-form')) {
                form = btn.closest('.reply-form');
                if (form) { form.classList.add('hidden'); return; }
                return;
            }
            form.classList.toggle('hidden');
        }
    </script>
}
