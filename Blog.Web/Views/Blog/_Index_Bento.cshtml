@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    string GetExcerpt(Blog.Core.Domain.Post p) =>
        !string.IsNullOrEmpty(p.MetaDescription) ? p.MetaDescription :
        !string.IsNullOrEmpty(p.Plaintext) ? (p.Plaintext.Length > 160 ? p.Plaintext[..157] + "…" : p.Plaintext) :
        string.Empty;
    var qParts = new List<string>();
    if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
    if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
    if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
    var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";
}

@* ── BENTO LAYOUT — CSS grid mosaic, image backgrounds + overlay *@
<style>
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        grid-auto-rows: 160px;
        gap: 10px;
    }
    .bento-cell { position: relative; overflow: hidden; border-radius: var(--r-2); background: var(--surface-2); }
    .bento-cell-wide  { grid-column: span 6; grid-row: span 2; }
    .bento-cell-half  { grid-column: span 3; grid-row: span 2; }
    .bento-cell-third { grid-column: span 2; grid-row: span 1; }
    .bento-cell img   { position:absolute;inset:0;width:100%;height:100%;object-fit:cover; }
    .bento-overlay    { position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7) 0%,rgba(0,0,0,.15) 60%,transparent 100%); }
    .bento-text       { position:absolute;bottom:0;left:0;right:0;padding:14px 16px; }
    .bento-eyebrow    { font-family:var(--sans);font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,.75);display:block;margin-bottom:4px; }
    .bento-title-lg   { font-family:var(--serif);font-size:clamp(1.125rem,2.5vw,1.75rem);font-weight:700;line-height:1.2;color:#fff;margin:0; }
    .bento-title-sm   { font-family:var(--serif);font-size:.9375rem;font-weight:700;line-height:1.25;color:#fff;margin:0; }
    .bento-title-xs   { font-family:var(--sans);font-size:.8125rem;font-weight:600;line-height:1.3;color:#fff;margin:0; }
    @@media (max-width: 640px) {
        .bento-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
        .bento-cell-wide, .bento-cell-half, .bento-cell-third { grid-column: span 1; grid-row: span 1; min-height: 200px; }
    }
</style>

<div style="max-width:var(--container);margin:0 auto;padding:var(--sp-10) var(--gutter);">

    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div style="margin-bottom:var(--sp-8);font-family:var(--sans);font-size:13px;color:var(--fg-muted);">
            Results for <strong>"@searchTerm"</strong> — <a href="/" style="color:var(--fg-muted);">clear</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div style="padding:var(--sp-16) 0;text-align:center;">
            <p style="font-family:var(--serif);font-size:1.25rem;color:var(--fg-muted);">No posts found.</p>
        </div>
    }
    else
    {
        <div class="bento-grid">
            @{int idx = 0;}
            @foreach (var post in Model.Items)
            {
                var excerpt = GetExcerpt(post);
                var cat = post.Categories?.FirstOrDefault();
                string cellClass;
                string titleClass;
                if (idx == 0)      { cellClass = "bento-cell bento-cell-wide";  titleClass = "bento-title-lg"; }
                else if (idx <= 2) { cellClass = "bento-cell bento-cell-half";  titleClass = "bento-title-sm"; }
                else               { cellClass = "bento-cell bento-cell-third"; titleClass = "bento-title-xs"; }

                <a href="/@post.Slug" class="@cellClass" style="text-decoration:none;display:block;">
                    @if (!string.IsNullOrEmpty(post.FeatureImage))
                    {
                        <img src="@post.FeatureImage" alt="@post.Title" loading="@(idx == 0 ? "eager" : "lazy")" />
                    }
                    <div class="bento-overlay"></div>
                    <div class="bento-text">
                        @if (cat != null)
                        {
                            <span class="bento-eyebrow">@cat.Name</span>
                        }
                        <h2 class="@titleClass">@post.Title</h2>
                    </div>
                </a>

                idx++;
            }
        </div>
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div style="max-width:var(--container);margin:var(--sp-16) auto 0;padding:0 var(--gutter);display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);padding-top:var(--sp-8);">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page-1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">← Newer</a>
            }
            else { <span></span> }
            <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@Model.Page / @Model.TotalPages</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page+1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">Older →</a>
            }
            else { <span></span> }
        </div>
    }
</div>
