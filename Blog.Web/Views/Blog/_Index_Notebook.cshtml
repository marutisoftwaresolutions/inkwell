@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    string GetExcerpt(Blog.Core.Domain.Post p) =>
        !string.IsNullOrEmpty(p.MetaDescription) ? p.MetaDescription :
        !string.IsNullOrEmpty(p.Plaintext) ? (p.Plaintext.Length > 200 ? p.Plaintext[..197] + "…" : p.Plaintext) :
        string.Empty;
    var qParts = new List<string>();
    if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
    if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
    if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
    var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";
}

@* ── NOTEBOOK LAYOUT — scholarly two-column with left marginalia ── *@
<div style="max-width:var(--container);margin:0 auto;padding:var(--sp-12) var(--gutter);">

    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div style="margin-bottom:var(--sp-8);font-family:var(--sans);font-size:13px;color:var(--fg-meta);">
            Results for <strong>"@searchTerm"</strong> — <a href="/" style="color:var(--fg-meta);">clear</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <p style="font-family:var(--serif);font-size:1.125rem;color:var(--fg-meta);padding:var(--sp-16) 0;text-align:center;">No entries yet.</p>
    }
    else
    {
        @foreach (var post in Model.Items)
        {
            var excerpt = GetExcerpt(post);
            var cat = post.Categories?.FirstOrDefault();
            <article style="display:grid;grid-template-columns:140px 1fr;gap:var(--sp-8);padding:var(--sp-10) 0;border-bottom:1px solid var(--border);">

                @* LEFT MARGINALIA — date, category, reading time *@
                <aside style="padding-top:4px;border-right:1px dashed var(--border);padding-right:var(--sp-8);">
                    <time style="display:block;font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--fg-meta);margin-bottom:var(--sp-4);">
                        @post.PublishedAt?.ToString("MMM d, yyyy")
                    </time>
                    @if (cat != null)
                    {
                        <a href="/?category=@cat.Slug" style="display:inline-block;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--link);text-decoration:none;margin-bottom:var(--sp-4);">@cat.Name</a>
                    }
                    @if (!string.IsNullOrEmpty(post.AuthorName))
                    {
                        <span style="display:block;font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@post.AuthorName</span>
                    }
                </aside>

                @* RIGHT BODY — title, image, excerpt *@
                <div>
                    <h2 style="font-family:var(--serif);font-size:clamp(1.2rem,2.5vw,1.5rem);font-weight:700;line-height:1.25;margin:0 0 var(--sp-4);">
                        <a href="/@post.Slug" style="color:var(--fg);text-decoration:none;">@post.Title</a>
                    </h2>
                    @if (!string.IsNullOrEmpty(post.FeatureImage))
                    {
                        <a href="/@post.Slug" style="display:block;margin-bottom:var(--sp-6);border-radius:var(--r-1);overflow:hidden;aspect-ratio:16/6;">
                            <img src="@post.FeatureImage" alt="@post.Title" loading="lazy"
                                 style="width:100%;height:100%;object-fit:cover;display:block;" />
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(excerpt))
                    {
                        <p style="font-family:var(--serif);font-size:1rem;line-height:1.75;color:var(--fg-body);margin:0 0 var(--sp-6);">@excerpt</p>
                    }
                    <a href="/@post.Slug" style="font-family:var(--sans);font-size:12px;font-weight:600;letter-spacing:0.04em;color:var(--link);text-decoration:none;">Read note →</a>
                </div>
            </article>
        }
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div style="margin-top:var(--sp-16);display:flex;align-items:center;justify-content:space-between;padding-top:var(--sp-8);border-top:1px solid var(--border);">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page-1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">← Newer</a>
            }
            else { <span></span> }
            <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@Model.Page / @Model.TotalPages</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page+1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">Older →</a>
            }
            else { <span></span> }
        </div>
    }
</div>
