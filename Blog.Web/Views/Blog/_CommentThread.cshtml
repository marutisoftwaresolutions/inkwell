@model Blog.Core.Domain.Comment
@{
    var maxDepth = 3;
    var slug = (string)ViewData["PostSlug"]!;
}

<div class="flex gap-4 pb-6 border-b border-dashed last:border-b-0" style="border-color: var(--border); @(Model.Depth > 0 ? $"margin-left: {Model.Depth * 2}rem; border-left: 2px solid var(--border); padding-left: 1rem;" : "")">
    <div class="w-10 h-10 rounded-full flex-shrink-0 overflow-hidden">
        <img src="/avatar/@System.Net.WebUtility.UrlEncode(string.IsNullOrEmpty(Model.AuthorName) ? "A" : Model.AuthorName)" alt="@Model.AuthorName" class="w-full h-full object-cover" loading="lazy" />
    </div>
    <div class="flex-1">
        <div class="flex items-baseline justify-between mb-1">
            <strong>@(string.IsNullOrEmpty(Model.AuthorName) ? "Anonymous" : Model.AuthorName)</strong>
            <time class="text-xs" style="color: var(--muted-foreground);">@Model.CreatedAt.ToString("MMM d, yyyy")</time>
        </div>
        <p style="color: var(--muted-foreground);">@Model.Content</p>

        @if (Model.Depth < maxDepth)
        {
            <button type="button" class="reply-toggle text-xs font-medium mt-2 hover:underline" style="color: var(--primary);" onclick="toggleReplyForm(this)">
                Reply
            </button>
            <div class="reply-form hidden mt-3">
                <form method="post" action="/@slug/comment" class="space-y-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="parentId" value="@Model.Id" />
                    <div class="grid md:grid-cols-2 gap-3">
                        <input type="text" name="authorName" placeholder="Name *" class="w-full px-3 py-1.5 text-sm border rounded-md focus:outline-none focus:ring-1 focus:ring-primary" style="background: var(--background); border-color: var(--border); color: var(--foreground);" required />
                        <input type="email" name="authorEmail" placeholder="Email *" class="w-full px-3 py-1.5 text-sm border rounded-md focus:outline-none focus:ring-1 focus:ring-primary" style="background: var(--background); border-color: var(--border); color: var(--foreground);" required />
                    </div>
                    <textarea name="content" rows="2" placeholder="Write a reply..." class="w-full px-3 py-1.5 text-sm border rounded-md focus:outline-none focus:ring-1 focus:ring-primary resize-y" style="background: var(--background); border-color: var(--border); color: var(--foreground);" required></textarea>
                    <div class="flex gap-2">
                        <button type="submit" class="px-4 py-1.5 text-xs font-medium rounded-md hover:opacity-90 transition-opacity" style="background: var(--primary); color: var(--primary-foreground);">Reply</button>
                        <button type="button" class="px-4 py-1.5 text-xs font-medium rounded-md hover:opacity-90 transition-opacity" style="background: var(--muted); color: var(--muted-foreground);" onclick="toggleReplyForm(this.closest('.reply-form').previousElementSibling)">Cancel</button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@if (Model.Replies.Any())
{
    <div class="space-y-4 mt-2">
        @foreach (var reply in Model.Replies)
        {
            <partial name="_CommentThread" model="reply" view-data="ViewData" />
        }
    </div>
}
