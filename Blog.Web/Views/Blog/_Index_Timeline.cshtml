@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    string GetExcerpt(Blog.Core.Domain.Post p) =>
        !string.IsNullOrEmpty(p.MetaDescription) ? p.MetaDescription :
        !string.IsNullOrEmpty(p.Plaintext) ? (p.Plaintext.Length > 160 ? p.Plaintext[..157] + "…" : p.Plaintext) :
        string.Empty;
    var qParts = new List<string>();
    if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
    if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
    if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
    var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";

    // Group posts by Month/Year for the timeline labels
    var groups = Model.Items
        .GroupBy(p => p.PublishedAt.HasValue
            ? p.PublishedAt.Value.ToString("MMMM yyyy")
            : "Undated")
        .ToList();
}

@* ── TIMELINE LAYOUT — vertical timeline with month/year labels *@
<div style="max-width:var(--container);margin:0 auto;padding:var(--sp-10) var(--gutter);">

    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div style="margin-bottom:var(--sp-8);font-family:var(--sans);font-size:13px;color:var(--fg-muted);">
            Results for <strong>"@searchTerm"</strong> — <a href="/" style="color:var(--fg-muted);">clear</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div style="padding:var(--sp-16) 0;text-align:center;">
            <p style="font-family:var(--serif);font-size:1.25rem;color:var(--fg-muted);">No posts found.</p>
        </div>
    }
    else
    {
        @foreach (var group in groups)
        {
            @* Month/year heading *@
            <div style="display:flex;align-items:center;gap:var(--sp-6);margin-bottom:var(--sp-6);">
                <div style="width:100px;flex-shrink:0;text-align:right;">
                    <span style="font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--fg-meta);">@group.Key</span>
                </div>
                <div style="width:12px;height:12px;border-radius:50%;background:var(--fg);flex-shrink:0;position:relative;z-index:1;"></div>
                <div style="flex:1;height:1px;background:var(--border);"></div>
            </div>

            @* Entries for this month *@
            @foreach (var post in group)
            {
                var excerpt = GetExcerpt(post);
                <div style="display:flex;gap:var(--sp-6);margin-bottom:var(--sp-8);">
                    @* Left column: date label, aligned under the month dot *@
                    <div style="width:100px;flex-shrink:0;text-align:right;padding-top:3px;">
                        <time style="font-family:var(--sans);font-size:12px;color:var(--fg-meta);">@post.PublishedAt?.ToString("d MMM")</time>
                    </div>
                    @* Vertical connector line + dot *@
                    <div style="width:12px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;">
                        <div style="width:1px;flex:1;background:var(--border);min-height:8px;"></div>
                        <div style="width:7px;height:7px;border-radius:50%;border:2px solid var(--fg);background:var(--bg);flex-shrink:0;"></div>
                        <div style="width:1px;flex:1;background:var(--border);"></div>
                    </div>
                    @* Right: post content *@
                    <article style="flex:1;padding-bottom:var(--sp-6);">
                        <h3 style="font-family:var(--serif);font-size:1.125rem;font-weight:700;line-height:1.25;margin:0 0 var(--sp-4);">
                            <a href="/@post.Slug" style="color:var(--fg);text-decoration:none;">@post.Title</a>
                        </h3>
                        @if (!string.IsNullOrEmpty(excerpt))
                        {
                            <p style="font-family:var(--sans);font-size:0.9rem;line-height:1.6;color:var(--fg-body);margin:0 0 var(--sp-4);max-width:56ch;">@excerpt</p>
                        }
                        <a href="/@post.Slug" style="font-family:var(--sans);font-size:12px;font-weight:600;color:var(--link);text-decoration:none;">Read →</a>
                    </article>
                </div>
            }
        }
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div style="max-width:var(--container);margin:var(--sp-16) auto 0;padding:0 var(--gutter);display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);padding-top:var(--sp-8);">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page-1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">← Newer</a>
            }
            else { <span></span> }
            <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@Model.Page / @Model.TotalPages</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page+1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">Older →</a>
            }
            else { <span></span> }
        </div>
    }
</div>
