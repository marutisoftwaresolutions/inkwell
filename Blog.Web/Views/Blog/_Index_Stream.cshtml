@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    string GetExcerpt(Blog.Core.Domain.Post p) =>
        !string.IsNullOrEmpty(p.MetaDescription) ? p.MetaDescription :
        !string.IsNullOrEmpty(p.Plaintext) ? (p.Plaintext.Length > 120 ? p.Plaintext[..117] + "…" : p.Plaintext) :
        string.Empty;
    var qParts = new List<string>();
    if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
    if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
    if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
    var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";
}

@* ── STREAM LAYOUT — microblog / threaded notes ────────────────── *@
<div style="max-width:640px;margin:0 auto;padding:var(--sp-10) var(--gutter);">

    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div style="margin-bottom:var(--sp-8);font-family:var(--sans);font-size:13px;color:var(--fg-muted);">
            Results for <strong>"@searchTerm"</strong> — <a href="/" style="color:var(--fg-muted);">clear</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div style="padding:var(--sp-16) 0;text-align:center;">
            <p style="font-family:var(--sans);font-size:1rem;color:var(--fg-muted);">Nothing here yet.</p>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:0;">
            @foreach (var post in Model.Items)
            {
                var excerpt = GetExcerpt(post);
                var initials = !string.IsNullOrEmpty(post.AuthorName)
                    ? string.Concat(post.AuthorName.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()))
                    : "B";
                <article style="display:flex;gap:var(--sp-6);padding:var(--sp-6) 0;border-bottom:1px solid var(--border);">
                    @* Avatar *@
                    <div style="flex-shrink:0;width:38px;height:38px;border-radius:50%;background:var(--surface-2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;">
                        <span style="font-family:var(--sans);font-size:12px;font-weight:700;color:var(--fg-muted);">@initials</span>
                    </div>
                    @* Content *@
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:baseline;gap:var(--sp-4);margin-bottom:6px;flex-wrap:wrap;">
                            @if (!string.IsNullOrEmpty(post.AuthorName))
                            {
                                <span style="font-family:var(--sans);font-size:13px;font-weight:700;color:var(--fg);">@post.AuthorName</span>
                            }
                            <time style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@post.PublishedAt?.ToString("MMM d, yyyy · h:mm tt")</time>
                        </div>
                        <p style="font-family:var(--sans);font-size:0.9375rem;line-height:1.55;color:var(--fg);margin:0 0 6px;">
                            <a href="/@post.Slug" style="color:var(--fg);text-decoration:none;font-weight:600;">@post.Title</a>
                        </p>
                        @if (!string.IsNullOrEmpty(excerpt))
                        {
                            <p style="font-family:var(--sans);font-size:0.875rem;line-height:1.55;color:var(--fg-body);margin:0 0 6px;">@excerpt</p>
                        }
                        <a href="/@post.Slug" style="font-family:var(--sans);font-size:12px;color:var(--link);text-decoration:none;">Read more</a>
                    </div>
                </article>
            }
        </div>
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div style="max-width:var(--container);margin:var(--sp-16) auto 0;padding:0 var(--gutter);display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);padding-top:var(--sp-8);">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page-1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">← Newer</a>
            }
            else { <span></span> }
            <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@Model.Page / @Model.TotalPages</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page+1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">Older →</a>
            }
            else { <span></span> }
        </div>
    }
</div>
