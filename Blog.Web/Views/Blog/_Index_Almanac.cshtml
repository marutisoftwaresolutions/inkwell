@using Blog.Core.Interfaces
@model PagedResult<Blog.Core.Domain.Post>
@{
    var searchTerm = ViewBag.SearchTerm as string;
    var selectedCategories = ViewBag.SelectedCategories as List<string> ?? new List<string>();
    var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    var qParts = new List<string>();
    if (!string.IsNullOrEmpty(searchTerm)) qParts.Add("search=" + Uri.EscapeDataString(searchTerm));
    if (selectedCategories.Any()) qParts.Add("category=" + string.Join(",", selectedCategories));
    if (selectedTags.Any()) qParts.Add("tags=" + string.Join(",", selectedTags));
    var baseQuery = qParts.Any() ? "&" + string.Join("&", qParts) : "";

    // Group by year for the archive index ledger
    var yearGroups = Model.Items
        .GroupBy(p => p.PublishedAt.HasValue ? p.PublishedAt.Value.Year.ToString() : "Undated")
        .OrderByDescending(g => g.Key)
        .ToList();
}

@* ── ALMANAC LAYOUT — archive index, chronological ledger ── *@
<div style="max-width:860px;margin:0 auto;padding:var(--sp-12) var(--gutter);">

    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div style="margin-bottom:var(--sp-8);font-family:var(--sans);font-size:13px;color:var(--fg-meta);">
            Results for <strong>"@searchTerm"</strong> — <a href="/" style="color:var(--fg-meta);">clear</a>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <p style="font-family:var(--serif);font-size:1.125rem;color:var(--fg-meta);padding:var(--sp-16) 0;text-align:center;">The archive is empty.</p>
    }
    else
    {
        @foreach (var yearGroup in yearGroups)
        {
            @* Year heading *@
            <div style="display:flex;align-items:center;gap:var(--sp-6);margin-bottom:var(--sp-6);margin-top:var(--sp-10);">
                <span style="font-family:var(--sans);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--fg);letter-spacing:-0.02em;flex-shrink:0;">@yearGroup.Key</span>
                <div style="flex:1;height:1px;background:var(--fg);"></div>
                <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);flex-shrink:0;">@yearGroup.Count() @(yearGroup.Count() == 1 ? "entry" : "entries")</span>
            </div>

            @* Ledger rows for each post *@
            <div style="border:1px solid var(--border);border-radius:var(--r-2);overflow:hidden;">
                @foreach (var post in yearGroup.OrderByDescending(p => p.PublishedAt))
                {
                    var cat = post.Categories?.FirstOrDefault();
                    <a href="/@post.Slug"
                       style="display:grid;grid-template-columns:52px 1fr auto;gap:var(--sp-6);align-items:center;padding:var(--sp-5) var(--sp-6);border-bottom:1px solid var(--border);text-decoration:none;background:var(--bg);transition:background 0.15s;">
                        @* Month/day *@
                        <time style="font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;color:var(--fg-meta);white-space:nowrap;">
                            @post.PublishedAt?.ToString("MMM d")
                        </time>
                        @* Title + category *@
                        <div style="overflow:hidden;">
                            <span style="font-family:var(--serif);font-size:0.9375rem;font-weight:600;color:var(--fg);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">@post.Title</span>
                            @if (cat != null)
                            {
                                <span style="font-family:var(--sans);font-size:10px;color:var(--link);letter-spacing:0.06em;text-transform:uppercase;">@cat.Name</span>
                            }
                        </div>
                        @* Author *@
                        @if (!string.IsNullOrEmpty(post.AuthorName))
                        {
                            <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);white-space:nowrap;">@post.AuthorName</span>
                        }
                    </a>
                }
            </div>
        }
    }

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <div style="margin-top:var(--sp-12);display:flex;align-items:center;justify-content:space-between;padding-top:var(--sp-8);border-top:1px solid var(--border);">
            @if (Model.Page > 1)
            {
                <a href="?page=@(Model.Page-1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">← Newer</a>
            }
            else { <span></span> }
            <span style="font-family:var(--sans);font-size:11px;color:var(--fg-meta);">@Model.Page / @Model.TotalPages</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a href="?page=@(Model.Page+1)@baseQuery" style="font-family:var(--sans);font-size:13px;font-weight:600;color:var(--fg);text-decoration:none;">Older →</a>
            }
            else { <span></span> }
        </div>
    }
</div>
