@model List<Blog.Core.Domain.Member>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Subscribers";

    var currentStatus = ViewBag.Status as string;
    var total = (int)ViewBag.Total;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var confirmedCount = (int)ViewBag.ConfirmedCount;

    string TabClass(string? s) => currentStatus == s
        ? "px-3 py-1.5 rounded-md text-xs font-medium bg-primary text-primary-foreground"
        : "px-3 py-1.5 rounded-md text-xs font-medium text-muted-foreground hover:text-foreground border border-border hover:border-primary/50";

    string StatusBadge(string status) => status switch
    {
        "confirmed"    => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
        "pending"      => "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400",
        "unsubscribed" => "bg-gray-100 text-gray-500 dark:bg-gray-800 dark:text-gray-400",
        _              => "bg-muted text-muted-foreground"
    };
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="text-lg font-semibold text-foreground">Subscribers</h2>
        <p class="text-sm text-muted-foreground mt-0.5">@confirmedCount confirmed subscriber@(confirmedCount == 1 ? "" : "s")</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="mb-4 px-4 py-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-200 dark:bg-green-900/20 dark:text-green-400 dark:border-green-800">
        @TempData["Success"]
    </div>
}

<div class="flex flex-wrap gap-2 mb-5">
    <a href="/admin/subscribers" class="@TabClass(null)">All (@total)</a>
    <a href="/admin/subscribers?status=confirmed" class="@TabClass("confirmed")">Confirmed</a>
    <a href="/admin/subscribers?status=pending" class="@TabClass("pending")">Pending</a>
    <a href="/admin/subscribers?status=unsubscribed" class="@TabClass("unsubscribed")">Unsubscribed</a>
</div>

<div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
    @if (!Model.Any())
    {
        <div class="px-5 py-12 text-center">
            <p class="text-sm text-muted-foreground">No subscribers found.</p>
        </div>
    }
    else
    {
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border bg-muted/40">
                    <th class="px-5 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wider">Email</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden sm:table-cell">Name</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wider">Status</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden md:table-cell">Joined</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wider hidden md:table-cell">Confirmed</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var m in Model)
                {
                    <tr class="hover:bg-muted/30 transition-colors">
                        <td class="px-5 py-3 font-medium text-foreground">@m.Email</td>
                        <td class="px-4 py-3 text-muted-foreground hidden sm:table-cell">@(m.Name ?? "—")</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium @StatusBadge(m.Status)">
                                @m.Status
                            </span>
                        </td>
                        <td class="px-4 py-3 text-muted-foreground hidden md:table-cell text-xs">@m.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td class="px-4 py-3 text-muted-foreground hidden md:table-cell text-xs">
                            @(m.ConfirmedAt.HasValue ? m.ConfirmedAt.Value.ToLocalTime().ToString("dd MMM yyyy") : "—")
                        </td>
                        <td class="px-4 py-3 text-right">
                            <form method="post" action="/admin/subscribers/delete/@m.Id?status=@currentStatus&page=@(page)"
                                  onsubmit="return confirm('Remove this subscriber?')">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="text-xs text-destructive hover:underline">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (totalPages > 1)
{
    <div class="flex items-center justify-between mt-4">
        <span class="text-xs text-muted-foreground">Page @(page) of @totalPages</span>
        <div class="flex gap-2">
            @if (page > 1)
            {
                <a href="/admin/subscribers?status=@currentStatus&page=@(page - 1)"
                   class="px-3 py-1.5 text-xs border border-border rounded-md hover:bg-muted">← Prev</a>
            }
            @if (page < totalPages)
            {
                <a href="/admin/subscribers?status=@currentStatus&page=@(page + 1)"
                   class="px-3 py-1.5 text-xs border border-border rounded-md hover:bg-muted">Next →</a>
            }
        </div>
    </div>
}
