@model Blog.Web.Models.AnalyticsDashboardViewModel
@using System.Text.Json
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Analytics";

    var dailyLabels  = JsonSerializer.Serialize(Model.DailyCounts.Select(d => d.Date));
    var dailyData    = JsonSerializer.Serialize(Model.DailyCounts.Select(d => d.Count));
    var srcLabels    = JsonSerializer.Serialize(Model.SourceBreakdown.Select(s => s.Label));
    var srcData      = JsonSerializer.Serialize(Model.SourceBreakdown.Select(s => s.Count));
    var srcColors    = JsonSerializer.Serialize(new[]{ "#6366f1","#0ea5e9","#10b981","#f59e0b","#ef4444","#8b5cf6","#ec4899","#14b8a6" });

    var qFrom   = Model.From.ToString("yyyy-MM-dd");
    var qTo     = Model.To.ToString("yyyy-MM-dd");
    var qPeriod = Model.Period;

    int maxViews = Model.TopPages.Count > 0 ? Model.TopPages.Max(p => p.Views) : 1;

    // Convert ISO-3166-1 alpha-2 code to regional indicator emoji flag
    string GetCountryFlag(string isoCode)
    {
        if (string.IsNullOrWhiteSpace(isoCode) || isoCode.Length != 2) return "🌐";
        var a = char.ToUpper(isoCode[0]) - 'A' + 0x1F1E6;
        var b = char.ToUpper(isoCode[1]) - 'A' + 0x1F1E6;
        return char.ConvertFromUtf32(a) + char.ConvertFromUtf32(b);
    }
}

<div id="analytics-dashboard">

@* Period selector *@
<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <h2 class="text-lg font-semibold text-foreground">Traffic Overview</h2>

    <div class="flex flex-wrap items-center gap-2">
        @foreach (var (label, val) in new[]{ ("Today","today"),("7 Days","7d"),("30 Days","30d"),("90 Days","90d") })
        {
            var active = qPeriod == val;
            <a href="?period=@val"
               class="px-3 py-1.5 rounded-md text-xs font-medium border transition-colors @(active ? "bg-primary text-primary-foreground border-primary" : "bg-background text-muted-foreground border-border hover:border-primary/50")">
                @label
            </a>
        }

        <form method="get" class="flex items-center gap-1">
            <input type="hidden" name="period" value="custom" />
            <input type="date" name="from" value="@qFrom"
                   class="h-8 rounded border border-input bg-background px-2 text-xs text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
            <span class="text-xs text-muted-foreground">to</span>
            <input type="date" name="to" value="@qTo"
                   class="h-8 rounded border border-input bg-background px-2 text-xs text-foreground focus:outline-none focus:ring-1 focus:ring-ring" />
            <button type="submit"
                    class="h-8 px-3 rounded bg-secondary text-secondary-foreground border border-border text-xs font-medium">Go</button>
        </form>

        <div class="flex items-center gap-1 ml-2">
            <a href="?period=@qPeriod&from=@qFrom&to=@qTo" id="btn-export-excel"
               href="/admin/analytics/export/excel?period=@qPeriod&from=@qFrom&to=@qTo"
               class="h-8 px-3 rounded bg-emerald-600 text-white text-xs font-medium flex items-center gap-1 hover:bg-emerald-700">
                <i data-lucide="table" class="w-3 h-3"></i> Excel
            </a>
            <div class="relative" x-data="{ open: false }">
                <button @@click="open=!open"
                        class="h-8 px-3 rounded bg-secondary text-secondary-foreground border border-border text-xs font-medium flex items-center gap-1">
                    <i data-lucide="download" class="w-3 h-3"></i> More
                </button>
                <div x-show="open" @@click.outside="open=false"
                     class="absolute right-0 mt-1 w-44 bg-card border border-border rounded-lg shadow-lg z-10 py-1">
                    <a href="/admin/analytics/export/csv?period=@qPeriod&from=@qFrom&to=@qTo&sheet=pages"
                       class="flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="file-text" class="w-3 h-3"></i> CSV — Top Pages
                    </a>
                    <a href="/admin/analytics/export/csv?period=@qPeriod&from=@qFrom&to=@qTo&sheet=sources"
                       class="flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="file-text" class="w-3 h-3"></i> CSV — Sources
                    </a>
                    <a href="/admin/analytics/export/csv?period=@qPeriod&from=@qFrom&to=@qTo&sheet=daily"
                       class="flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="file-text" class="w-3 h-3"></i> CSV — Daily
                    </a>
                    <a href="/admin/analytics/export/csv?period=@qPeriod&from=@qFrom&to=@qTo&sheet=referrers"
                       class="flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="file-text" class="w-3 h-3"></i> CSV — Referrers
                    </a>
                    <a href="/admin/analytics/export/csv?period=@qPeriod&from=@qFrom&to=@qTo&sheet=countries"
                       class="flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="file-text" class="w-3 h-3"></i> CSV — Countries
                    </a>
                    <hr class="my-1 border-border" />
                    <button onclick="printDashboard()"
                            class="w-full flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="printer" class="w-3 h-3"></i> Print / Save PDF
                    </button>
                    <button onclick="saveImage()"
                            class="w-full flex items-center gap-2 px-3 py-2 text-xs hover:bg-muted">
                        <i data-lucide="image" class="w-3 h-3"></i> Save as Image
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* Summary cards *@
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    @{
        var cards = new (string Icon, string Label, string Value)[]
        {
            ("eye",          "Total Views",      Model.TotalViews.ToString("N0")),
            ("layout-grid",  "Unique Pages",     Model.UniquePages.ToString("N0")),
            ("trending-up",  "Top Source",       Model.TopSource),
            ("link",         "Referrers",        Model.TotalReferrers.ToString("N0")),
        };
    }
    @foreach (var card in cards)
    {
        <div class="bg-card border border-border rounded-xl p-4 shadow-sm">
            <div class="flex items-center gap-2 mb-2">
                <i data-lucide="@card.Icon" class="w-4 h-4 text-muted-foreground"></i>
                <span class="text-xs text-muted-foreground font-medium">@card.Label</span>
            </div>
            <p class="text-2xl font-bold text-foreground truncate">@card.Value</p>
        </div>
    }
</div>

@* Charts row *@
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
    <div class="lg:col-span-2 bg-card border border-border rounded-xl p-5 shadow-sm">
        <h3 class="text-sm font-semibold text-foreground mb-4">Daily Page Views</h3>
        <div class="relative h-56">
            <canvas id="chartDaily"></canvas>
        </div>
    </div>
    <div class="bg-card border border-border rounded-xl p-5 shadow-sm">
        <h3 class="text-sm font-semibold text-foreground mb-4">Traffic Sources</h3>
        @if (Model.SourceBreakdown.Count == 0)
        {
            <div class="flex items-center justify-center h-56 text-sm text-muted-foreground">No data yet</div>
        }
        else
        {
            <div class="relative h-44 mb-4">
                <canvas id="chartSources"></canvas>
            </div>
            <ul class="space-y-1.5 mt-2">
                @{
                    var palette = new[]{ "#6366f1","#0ea5e9","#10b981","#f59e0b","#ef4444","#8b5cf6","#ec4899","#14b8a6" };
                    int ci = 0;
                }
                @foreach (var s in Model.SourceBreakdown.Take(6))
                {
                    var color = palette[ci++ % palette.Length];
                    var pct = Model.TotalViews > 0 ? Math.Round(s.Count * 100.0 / Model.TotalViews, 1) : 0;
                    <li class="flex items-center justify-between text-xs">
                        <span class="flex items-center gap-1.5">
                            <span class="w-2.5 h-2.5 rounded-sm flex-shrink-0" style="background:@color"></span>
                            <span class="text-foreground truncate max-w-32">@s.Label</span>
                        </span>
                        <span class="text-muted-foreground font-medium">@s.Count <span class="opacity-60">(@pct%)</span></span>
                    </li>
                }
            </ul>
        }
    </div>
</div>

@* Tables row *@
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-border">
            <h3 class="text-sm font-semibold text-foreground">Top Pages</h3>
        </div>
        <div class="divide-y divide-border">
            @if (!Model.TopPages.Any())
            {
                <p class="px-5 py-8 text-sm text-muted-foreground text-center">No page views recorded yet.</p>
            }
            @foreach (var pageView in Model.TopPages.Take(15))
            {
                var barPct = maxViews > 0 ? (pageView.Views * 100 / maxViews) : 0;
                <div class="px-5 py-3">
                    <div class="flex items-center justify-between mb-1">
                        <span class="text-xs text-foreground font-medium truncate max-w-xs">@pageView.Path</span>
                        <span class="text-xs text-muted-foreground font-semibold ml-2 flex-shrink-0">@pageView.Views.ToString("N0")</span>
                    </div>
                    <div class="h-1 bg-muted rounded-full">
                        <div class="h-1 bg-primary rounded-full" style="width:@barPct%"></div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="space-y-6">
        <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-border">
                <h3 class="text-sm font-semibold text-foreground">Top Referrers</h3>
            </div>
            <div class="divide-y divide-border">
                @if (!Model.TopReferrers.Any())
                {
                    <p class="px-5 py-6 text-sm text-muted-foreground text-center">No referrer data yet.</p>
                }
                @foreach (var ref_ in Model.TopReferrers.Take(8))
                {
                    <div class="px-5 py-2.5 flex items-center justify-between">
                        <span class="text-xs text-foreground truncate max-w-xs">@ref_.Referrer</span>
                        <span class="text-xs font-semibold text-muted-foreground ml-2 flex-shrink-0">@ref_.Count</span>
                    </div>
                }
            </div>
        </div>

        @if (Model.Campaigns.Any())
        {
            <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
                <div class="px-5 py-4 border-b border-border">
                    <h3 class="text-sm font-semibold text-foreground">UTM Campaigns</h3>
                </div>
                <div class="divide-y divide-border">
                    @foreach (var camp in Model.Campaigns.Take(8))
                    {
                        <div class="px-5 py-2.5 flex items-center justify-between">
                            <span class="text-xs text-foreground truncate max-w-xs">@camp.Campaign</span>
                            <span class="text-xs font-semibold text-muted-foreground ml-2 flex-shrink-0">@camp.Count</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@* Geography row *@
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    @* Countries *@
    <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
            <h3 class="text-sm font-semibold text-foreground">Top Countries</h3>
            @if (Model.TopCountries.Any())
            {
                <a href="/admin/analytics/export/csv?period=@qPeriod&from=@qFrom&to=@qTo&sheet=countries"
                   class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1">
                    <i data-lucide="download" class="w-3 h-3"></i> CSV
                </a>
            }
        </div>
        @if (!Model.TopCountries.Any())
        {
            <div class="px-5 py-8 text-center">
                <p class="text-sm text-muted-foreground">No geo data yet.</p>
                <p class="text-xs text-muted-foreground mt-1">Country and region are captured automatically from visitor IPs on new page views.</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-border">
                @{
                    int maxCountry = Model.TopCountries.Max(c => c.Count);
                }
                @foreach (var ctry in Model.TopCountries.Take(10))
                {
                    var pct = maxCountry > 0 ? (ctry.Count * 100 / maxCountry) : 0;
                    <div class="px-5 py-3">
                        <div class="flex items-center justify-between mb-1">
                            <span class="flex items-center gap-2 text-xs font-medium text-foreground">
                                <span class="text-base leading-none">@GetCountryFlag(ctry.Country)</span>
                                @ctry.Country
                            </span>
                            <span class="text-xs font-semibold text-muted-foreground ml-2 flex-shrink-0">@ctry.Count.ToString("N0")</span>
                        </div>
                        <div class="h-1 bg-muted rounded-full">
                            <div class="h-1 bg-primary rounded-full" style="width:@pct%"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* Regions / States *@
    <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-border">
            <h3 class="text-sm font-semibold text-foreground">Top Regions / States</h3>
        </div>
        @if (!Model.TopRegions.Any())
        {
            <div class="px-5 py-8 text-center">
                <p class="text-sm text-muted-foreground">No region data yet.</p>
                <p class="text-xs text-muted-foreground mt-1">Regions are resolved from visitor IPs on new page views.</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-border">
                @{
                    int maxRegion = Model.TopRegions.Max(r => r.Count);
                }
                @foreach (var reg in Model.TopRegions.Take(10))
                {
                    var pct = maxRegion > 0 ? (reg.Count * 100 / maxRegion) : 0;
                    <div class="px-5 py-3">
                        <div class="flex items-center justify-between mb-1">
                            <span class="text-xs font-medium text-foreground truncate max-w-xs">@reg.Region</span>
                            <span class="text-xs font-semibold text-muted-foreground ml-2 flex-shrink-0">@reg.Count.ToString("N0")</span>
                        </div>
                        <div class="h-1 bg-muted rounded-full">
                            <div class="h-1 bg-indigo-500 rounded-full" style="width:@pct%"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

</div>

@section Scripts {
<script src="~/lib/chartjs/chart.umd.min.js"></script>
<script src="~/lib/html2canvas/html2canvas.min.js"></script>
<script>
// Chart.js — themed colours
const style = getComputedStyle(document.documentElement);
const fg    = style.getPropertyValue('--foreground').trim() || '#1a1a1a';
const muted = style.getPropertyValue('--muted-foreground').trim() || '#6b7280';
const grid  = style.getPropertyValue('--border').trim() || '#e5e7eb';

Chart.defaults.color = muted;
Chart.defaults.font.family = "'Geist', 'Inter', sans-serif";
Chart.defaults.font.size   = 11;

// Daily line chart
const ctxDaily = document.getElementById('chartDaily');
if (ctxDaily) {
    new Chart(ctxDaily, {
        type: 'line',
        data: {
            labels: @Html.Raw(dailyLabels),
            datasets: [{
                label: 'Page Views',
                data: @Html.Raw(dailyData),
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99,102,241,0.08)',
                borderWidth: 2,
                pointRadius: @(Model.DailyCounts.Count > 30 ? 0 : 3),
                tension: 0.3,
                fill: true,
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'transparent' }, ticks: { maxTicksLimit: 8, maxRotation: 0 } },
                y: { grid: { color: 'rgba(128,128,128,0.1)' }, beginAtZero: true,
                     ticks: { precision: 0 } }
            }
        }
    });
}

// Source doughnut chart
const ctxSrc = document.getElementById('chartSources');
if (ctxSrc && @Html.Raw(srcData) .length > 0) {
    new Chart(ctxSrc, {
        type: 'doughnut',
        data: {
            labels: @Html.Raw(srcLabels),
            datasets: [{ data: @Html.Raw(srcData), backgroundColor: @Html.Raw(srcColors), borderWidth: 2, borderColor: 'transparent' }]
        },
        options: {
            responsive: true, maintainAspectRatio: false, cutout: '68%',
            plugins: { legend: { display: false } }
        }
    });
}

// Export helpers
function printDashboard() {
    window.print();
}

function saveImage() {
    const el = document.getElementById('analytics-dashboard');
    html2canvas(el, { scale: 2, useCORS: true, backgroundColor: '#ffffff' }).then(canvas => {
        const link = document.createElement('a');
        link.download = 'analytics-dashboard.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
    });
}

// Fix Excel link
document.getElementById('btn-export-excel')?.setAttribute('href',
    '/admin/analytics/export/excel?period=@qPeriod&from=@qFrom&to=@qTo');
</script>

<style>
@@media print {
    nav, aside, header, .no-print { display: none !important; }
    #analytics-dashboard { padding: 0; }
    body { background: white !important; }
    .bg-card { box-shadow: none !important; border: 1px solid #e5e7eb !important; }
}
</style>
}
