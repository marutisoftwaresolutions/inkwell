{
  "DeploymentMode": "SelfHosted",
  "ConnectionStrings": {
    // SQL Server (recommended for production):
    // "DefaultConnection": "Server=YOUR_SERVER;Database=blog;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
    //
    // SQL Server LocalDB (local dev):
    // "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=blog;Trusted_Connection=True;TrustServerCertificate=True;"
    //
    // SQLite (lightweight / self-hosted):
    "DefaultConnection": "Data Source=beacon.db"
  },
  "Admin": {
    "Email": "",
    "PasswordHash": ""
  },
  "Jwt": {
    // Generate a secret: openssl rand -base64 48
    "Key": "REPLACE_WITH_A_RANDOM_64_CHAR_SECRET",
    "Issuer": "opticalsoftware.org",
    "Audience": "opticalsoftware.org"
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "noreply@example.com",
    "Password": "YOUR_SMTP_PASSWORD",
    "FromEmail": "noreply@example.com",
    "FromName": "Your Blog Name"
  },
  "GeoLite2DbPath": "geoip/GeoLite2-City.mmdb",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
